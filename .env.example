TELEGRAM_BOT_TOKEN=

# Proveedor principal recomendado para pruebas
LLM_PROVIDER=openai
LLM_MODE=auto

# OpenAI API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MAX_OUTPUT_TOKENS=500
OPENAI_TEMPERATURE=0.2
OPENAI_BASE_URL=https://api.openai.com/v1

# IA local opcional. No se consulta ni se inicia si OLLAMA_ENABLED=false.
OLLAMA_ENABLED=false
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120
OLLAMA_THINK=false
OLLAMA_TEMPERATURE=0.2
OLLAMA_MAX_TOKENS=400
OLLAMA_KEEP_ALIVE=5m

# Proveedores opcionales compatibles con cliente OpenAI
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_NAME=PachaBot
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
CHAT_MODEL=gpt-5.4-mini
CHAT_MODEL_FALLBACKS=
MODEL_RETRY_COOLDOWN_SECONDS=180

APP_ENV=development
LOG_LEVEL=INFO
EMBEDDING_MODEL=local-tfidf
RETRIEVAL_TOP_K=4
RETRIEVAL_MIN_SCORE=0.35
RETRIEVAL_MAX_RESULTS=5
CHUNK_SIZE=700
CHUNK_OVERLAP=120
CONFIDENCE_THRESHOLD=0.05
MEMORY_HISTORY_LIMIT=12
MEMORY_MAX_TURNS=40
ASSISTANT_MAX_SOURCES=3
RAG_DEBUG_TRACE=false
