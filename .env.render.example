# Configuracion recomendada para desplegar PachaBot en Render.
# Copia estos valores en Render > Environment > Environment Variables.
# No pegues tu API key real en GitHub.

# Proveedor LLM principal en Render
LLM_PROVIDER=openai
OPENAI_API_KEY=coloca_aqui_tu_api_key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MAX_OUTPUT_TOKENS=500
OPENAI_TEMPERATURE=0.2

# Ollama no debe usarse en Render porque depende de tu maquina local
OLLAMA_ENABLED=false
OLLAMA_MODEL=qwen3.5:0.8b
OLLAMA_BASE_URL=http://localhost:11434

# Retrieval / RAG
RETRIEVAL_MIN_SCORE=0.35
RETRIEVAL_MAX_RESULTS=5

# Configuracion de ejecucion
LOG_LEVEL=INFO

# Telegram es opcional para el deploy web.
# Si solo usaras el simulador, puedes dejarlo vacio en Render.
TELEGRAM_BOT_TOKEN=
